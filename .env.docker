# Docker Persistence Configuration
# Path where persistent data will be stored
# Default: ./.docker/data (relative to docker-compose.yaml)
BOLT_DATA_PATH=./.docker/data

# Cache directory for build cache
BOLT_CACHE_PATH=./.docker/cache

# NPM cache directory
BOLT_NPM_CACHE_PATH=./.docker/npm-cache

# Optional: Use absolute paths for production deployments
# BOLT_DATA_PATH=/data/bolt/data
# BOLT_CACHE_PATH=/data/bolt/cache
# BOLT_NPM_CACHE_PATH=/data/bolt/npm-cache
